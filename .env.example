# Copy to .env and export before starting the backend, or use systemd EnvironmentFile.

# --- DashScope (通义千问，必填用于对话) ---
DASHSCOPE_API_KEY=sk-your-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus
# DASHSCOPE_CONNECT_TIMEOUT_MS=10000
# DASHSCOPE_READ_TIMEOUT_MS=120000
# DASHSCOPE_MAX_TOKENS=4096
# DASHSCOPE_TEMPERATURE=0.3

# --- Redis（限流）---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- JWT（生产务必更换长随机串）---
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
# JWT_EXPIRATION_MS=86400000

# --- SQLite 数据文件路径（可选，默认 backend 运行目录下 ./data/chatagent.db）---
# SQLITE_PATH=/var/lib/chatagent/chatagent.db

# --- 首次启动默认管理员（仅当库中不存在该用户名时创建）---
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_PASSWORD=change-me

# --- CORS（逗号分隔，生产填你的前端域名）---
# CORS_ALLOWED_ORIGINS=https://your-domain.com

# --- Agent ---
# AGENT_MAX_STEPS=8
# RATE_LIMIT_AGENT_PER_MINUTE=30

# --- Spring ---
# SPRING_PROFILES_ACTIVE=prod
# SERVER_PORT=8080
